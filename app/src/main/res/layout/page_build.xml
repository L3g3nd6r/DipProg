<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/buildPageContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            layout="@layout/content_build_list"
            android:id="@+id/buildListInclude" />

        <include
            layout="@layout/content_build_detail"
            android:id="@+id/buildDetailInclude"
            android:visibility="gone" />

        <include
            layout="@layout/content_component_picker_full"
            android:id="@+id/componentPickerInclude"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
