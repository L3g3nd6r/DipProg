<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/buildPageContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            layout="@layout/content_build_list"
            android:id="@+id/buildListInclude" />

        <include
            layout="@layout/content_build_detail"
            android:id="@+id/buildDetailInclude"
            android:visibility="gone" />

        <include
            layout="@layout/content_component_picker_full"
            android:id="@+id/componentPickerInclude"
            android:visibility="gone" />

        <include
            layout="@layout/content_cart"
            android:id="@+id/buildCartInclude"
            android:visibility="gone" />

    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buildCartFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/cart_fab_cd"
        app:fabCustomSize="48dp"
        app:maxImageSize="22dp"
        app:srcCompat="@drawable/ic_cart" />

</FrameLayout>
