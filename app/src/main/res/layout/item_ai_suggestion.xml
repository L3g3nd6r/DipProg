<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/md_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/ai_suggestion_accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ai_suggestion_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="@string/ai_suggestion_badge"
                    android:textAllCaps="true"
                    android:textColor="@color/ai_suggestion_badge_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◆"
                    android:textColor="@color/ai_suggestion_accent"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/suggestionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:letterSpacing="0.02"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                tools:text="Оптимальная сборка" />

            <TextView
                android:id="@+id/suggestionDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_ai_suggestion_desc"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:lineSpacingMultiplier="1.15"
                android:padding="14dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Кратко о комплектации и цене…" />

            <LinearLayout
                android:id="@+id/suggestionProsBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_ai_suggestion_pros"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/suggestionProsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_suggestion_pros_title"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/ai_pros_label" />

                <TextView
                    android:id="@+id/suggestionPros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:lineSpacingMultiplier="1.2"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/ai_pros_block_text"
                    tools:text="• Пункт" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/suggestionConsBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_ai_suggestion_cons"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/suggestionConsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_suggestion_cons_title"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/ai_cons_label" />

                <TextView
                    android:id="@+id/suggestionCons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:lineSpacingMultiplier="1.2"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/ai_cons_block_text"
                    tools:text="• Пункт" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/suggestionDetailsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center"
                    android:minHeight="52dp"
                    android:text="@string/ai_suggestion_details"
                    android:textColor="@color/md_primary"
                    android:visibility="gone"
                    app:backgroundTint="@color/ai_details_button_bg"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/md_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/suggestionAddButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="52dp"
                    android:text="@string/ai_suggestion_save_build"
                    android:visibility="gone"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
