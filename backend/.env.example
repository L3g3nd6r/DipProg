PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dipproj
JWT_SECRET=your-secret-key-change-in-production
# Email аккаунта(ов) сборщика, через запятую
# ASSEMBLER_EMAILS=builder@mail.com,second-builder@mail.com

# --- Почта (Brevo / Sendinblue) ---
# Рекомендуется добавить BREVO_API_KEY (ключ API v3, начинается с xkeysib-) из раздела SMTP & API → API keys.
# Отправка через HTTPS API даёт лучшую доставляемость, чем только SMTP (письма не «теряются» после приёма сервером).
# BREVO_API_KEY=xkeysib-...
#
# SMTP (если API не задан — используется SMTP; можно держать оба)
# BREVO_SMTP_LOGIN=ваш@email.com
# BREVO_SMTP_KEY=smtp-ключ
# Адрес «От» — обязательно verified sender в Brevo
# BREVO_SENDER_EMAIL=noreply@ваш-домен.ru
# Принудительно только SMTP: MAIL_DRIVER=smtp
#
# Альтернатива: Resend (если заведёте аккаунт)
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@ваш-домен-verified-в-resend.com

# --- ИИ в облаке (без установки модели на сервер) ---
# Ключ с platform.openai.com или совместимого провайдера (Groq, OpenRouter и т.д.)
# OPENAI_API_KEY=your-key-from-platform.openai.com
# OPENAI_MODEL=gpt-4o-mini
# Для OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=60000

# --- Локальная Ollama (если OPENAI_API_KEY не задан) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
