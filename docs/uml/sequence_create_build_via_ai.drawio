        </mxCell>
        <mxCell id="m8" value="8. POST /api/builds/from-suggestion  (auth) { name, component_ids }" style="endArrow=block;html=1;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="app" target="server">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="648" as="sourcePoint"/>
