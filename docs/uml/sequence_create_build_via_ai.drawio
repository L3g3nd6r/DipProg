          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="9. Создаёт сборку (builds) и добавляет компоненты (build_components)" style="endArrow=block;html=1;strokeColor=#333333;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="server" target="server">
