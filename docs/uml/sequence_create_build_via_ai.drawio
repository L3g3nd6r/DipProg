          <mxGeometry x="80" y="60" width="160" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="app" value="Приложение (Android)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="200" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="server" value="Сервер (API + нейросеть)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="760" y="60" width="220" height="44" as="geometry"/>
        </mxCell>

        <!-- Линии жизни (центры: 160, 500, 870) -->
        <mxCell id="line_user" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1" source="user" target="user">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="114" as="sourcePoint"/>
            <mxPoint x="160" y="1000" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="line_app" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1" source="app" target="app">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="114" as="sourcePoint"/>
            <mxPoint x="500" y="1000" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
