            <mxPoint x="870" y="1000" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Фаза 1 -->
        <mxCell id="phase1" value="Фаза 1 — Запрос подбора у нейросети" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="138" width="1000" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="1. Вводит запрос в чат (напр. «Сборка для игр до 80 000 ₽»)" style="endArrow=block;html=1;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="user" target="app">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="188" as="sourcePoint"/>
            <mxPoint x="500" y="188" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="2. Показывает «Думаю...»" style="endArrow=block;html=1;strokeColor=#333333;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="app" target="user">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="248" as="sourcePoint"/>
            <mxPoint x="160" y="248" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3. POST /api/ai/build-suggestions  { message, build_summary? }" style="endArrow=block;html=1;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="app" target="server">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="308" as="sourcePoint"/>
            <mxPoint x="870" y="308" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="4. Вызов нейросети (LLM), подбор компонентов по каталогу" style="endArrow=block;html=1;strokeColor=#333333;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="server" target="server">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="905" y="368" as="sourcePoint"/>
            <mxPoint x="835" y="368" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="5. Ответ: { text, suggestions[] }  (название, описание, pros, cons, component_ids)" style="endArrow=block;html=1;strokeColor=#333333;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="server" target="app">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="870" y="428" as="sourcePoint"/>
            <mxPoint x="500" y="428" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="6. Показывает текст ИИ и карточки подборок (плитки)" style="endArrow=block;html=1;strokeColor=#333333;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="app" target="user">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="488" as="sourcePoint"/>
            <mxPoint x="160" y="488" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Фаза 2 -->
        <mxCell id="phase2" value="Фаза 2 — Создание сборки из подбора" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="538" width="1000" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="m7" value="7. Нажимает «Добавить в мои сборки» на карточке" style="endArrow=block;html=1;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="user" target="app">
          <mxGeometry relative="1" as="geometry">
